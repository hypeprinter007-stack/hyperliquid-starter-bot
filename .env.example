# Hyperliquid
HL_WALLET_PRIVATE_KEY=your_agent_wallet_private_key
HL_ACCOUNT_ADDRESS=your_hl_account_address

# SignalFuse — pick ONE payment method:

# Option 1: Credit token (simplest — works with plain HTTP)
# Get 5 free calls: curl -X POST https://api.signalfuse.co/v1/credits/trial -H "Content-Type: application/json" -d '{"wallet":"YOUR_ETH_ADDRESS"}'
SIGNALFUSE_CREDIT_TOKEN=

# Option 2: x402 per-call (automatic USDC on Base — requires x402 + eth-account packages)
# Uncomment and set an Ethereum private key with USDC on Base:
# SIGNALFUSE_WALLET_KEY=
